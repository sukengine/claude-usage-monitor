# คัดลอกเป็น .env

# API key แบบสุ่ม 32 อักษร (ใช้กับ server.py — Docker API แบบเดิม ถ้ายังใช้)
# สร้างคีย์: head -c 48 /dev/urandom | base64 | tr -dc 'A-Za-z0-9' | head -c 32; echo
API_KEY=CHANGE_ME_32_CHAR_RANDOM_KEY

# Upstash Redis (push model) — get-usage.sh ใช้ WRITE token push ค่าขึ้นคลาวด์
# widget ดึงด้วย READ-ONLY token (คนละตัว) ไม่ต้องอยู่ในไฟล์นี้
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_WRITE_TOKEN=YOUR_UPSTASH_WRITE_TOKEN
